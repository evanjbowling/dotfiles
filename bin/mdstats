#!/usr/bin/env python3
# Purpose: compute statistics for a markdown file

import argparse
import pathlib
import re
import sys

PROSE_WPM = 200
CODE_SEC_PER_LINE = 2
IMAGE_SEC_EACH = 12


def strip_inline(text):
    text = re.sub(r'!\[[^\]]*\]\([^)]*\)', '', text)
    text = re.sub(r'!\[[^\]]*\]\[[^\]]*\]', '', text)
    text = re.sub(r'\[([^\]]+)\]\([^)]*\)', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\[[^\]]*\]', r'\1', text)
    text = re.sub(r'`[^`]+`', '', text)
    text = re.sub(r'\*{1,3}([^*\n]+)\*{1,3}', r'\1', text)
    text = re.sub(r'_{1,3}([^_\n]+)_{1,3}', r'\1', text)
    text = re.sub(r'<[^>]+>', '', text)
    return re.sub(r'\s+', ' ', text).strip()


def split_sentences(text):
    parts = re.split(r'(?<=[.!?])\s+(?=[A-Z"\'])', text)
    return [s.strip() for s in parts if s.strip()]


def analyze(text):
    lines = text.splitlines()

    in_code_block = False
    code_block_lines = 0
    images = 0
    list_items = 0
    paragraphs = 0

    prose_chunks = []
    current_chunk = []

    def flush():
        nonlocal paragraphs
        if current_chunk:
            text = ' '.join(current_chunk)
            if text:
                paragraphs += 1
                prose_chunks.append(text)
            current_chunk.clear()

    for line in lines:
        stripped = line.strip()

        if re.match(r'^(`{3,}|~{3,})', stripped):
            if in_code_block:
                in_code_block = False
            else:
                flush()
                in_code_block = True
            continue

        if in_code_block:
            code_block_lines += 1
            continue

        images += len(re.findall(r'!\[[^\]]*\]\([^)]*\)', line))
        images += len(re.findall(r'!\[[^\]]*\]\[[^\]]*\]', line))

        if re.match(r'^#{1,6}\s', stripped):
            flush()
            continue

        if not stripped:
            flush()
            continue

        m = re.match(r'^\s*(?:[-*+]|\d+\.)\s+(.*)', line)
        if m:
            flush()
            list_items += 1
            item_text = strip_inline(m.group(1))
            if item_text:
                prose_chunks.append(item_text)
            continue

        cleaned = strip_inline(stripped)
        if cleaned:
            current_chunk.append(cleaned)

    flush()

    words = sum(len(c.split()) for c in prose_chunks)
    sentences = sum(len(split_sentences(c)) for c in prose_chunks)

    prose_sec = round((words / PROSE_WPM) * 60)
    code_sec = code_block_lines * CODE_SEC_PER_LINE
    image_sec = images * IMAGE_SEC_EACH
    total_sec = prose_sec + code_sec + image_sec

    return {
        'words': words,
        'sentences': sentences,
        'paragraphs': paragraphs,
        'list_items': list_items,
        'code_block_lines': code_block_lines,
        'images': images,
        'prose_reading_time_sec': prose_sec,
        'code_reading_time_sec': code_sec,
        'image_reading_time_sec': image_sec,
        'total_reading_time_sec': total_sec,
    }


def main():
    parser = argparse.ArgumentParser(
        prog='mdstats',
        description='Compute statistics for a markdown file.',
    )
    parser.add_argument('file', type=pathlib.Path, nargs='?')
    args = parser.parse_args()

    if args.file is None:
        parser.print_usage()
        sys.exit(1)

    if not args.file.is_file():
        print(f'Error: file not found: {args.file}')
        sys.exit(1)

    text = args.file.read_text(encoding='utf-8')
    stats = analyze(text)
    for key, value in stats.items():
        print(f'{key}: {value}')


if __name__ == '__main__':
    main()

#!/usr/bin/env python3
# Purpose: extract sentences and list items from a markdown file, one per line

import argparse
import pathlib
import re
import sys


def strip_inline(text):
    text = re.sub(r'!\[[^\]]*\]\([^)]*\)', '', text)
    text = re.sub(r'!\[[^\]]*\]\[[^\]]*\]', '', text)
    text = re.sub(r'\[([^\]]+)\]\([^)]*\)', r'\1', text)
    text = re.sub(r'\[([^\]]+)\]\[[^\]]*\]', r'\1', text)
    text = re.sub(r'`[^`]+`', '', text)
    text = re.sub(r'\*{1,3}([^*\n]+)\*{1,3}', r'\1', text)
    text = re.sub(r'_{1,3}([^_\n]+)_{1,3}', r'\1', text)
    text = re.sub(r'<[^>]+>', '', text)
    return re.sub(r'\s+', ' ', text).strip()


def split_sentences(text):
    parts = re.split(r'(?<=[.!?])\s+(?=[A-Z"\'])', text)
    return [s.strip() for s in parts if s.strip()]


def extract_lines(text):
    lines = text.splitlines()
    in_code_block = False
    prose_chunks = []
    current_chunk = []

    def flush():
        if current_chunk:
            prose_chunks.append(' '.join(current_chunk))
            current_chunk.clear()

    for line in lines:
        stripped = line.strip()

        if re.match(r'^(`{3,}|~{3,})', stripped):
            if in_code_block:
                in_code_block = False
            else:
                flush()
                in_code_block = True
            continue

        if in_code_block:
            continue

        if re.match(r'^#{1,6}\s', stripped):
            flush()
            continue

        if not stripped:
            flush()
            continue

        m = re.match(r'^\s*(?:[-*+]|\d+\.)\s+(.*)', line)
        if m:
            flush()
            item_text = strip_inline(m.group(1))
            if item_text:
                prose_chunks.append(item_text)
            continue

        cleaned = strip_inline(stripped)
        if cleaned:
            current_chunk.append(cleaned)

    flush()

    sentences = []
    for chunk in prose_chunks:
        sentences.extend(split_sentences(chunk))
    return sentences


def main():
    parser = argparse.ArgumentParser(
        prog='mdlines',
        description='Extract sentences and list items from a markdown file, one per line.',
    )
    parser.add_argument('file', type=pathlib.Path, nargs='?')
    args = parser.parse_args()

    if args.file is None:
        parser.print_usage()
        sys.exit(1)

    if not args.file.is_file():
        print(f'Error: file not found: {args.file}')
        sys.exit(1)

    text = args.file.read_text(encoding='utf-8')
    sentences = extract_lines(text)
    if sentences:
        print('\n'.join(sentences))


if __name__ == '__main__':
    main()

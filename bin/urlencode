#!/usr/bin/env python3
# urlencode - URL encode or decode strings
# Usage:
#   urlencode <text>          # encode (default)
#   urlencode -d <text>       # decode
#   urlencode --decode <text> # decode
#   echo "text" | urlencode   # encode from stdin
#   echo "text" | urlencode -d # decode from stdin

import argparse
import os
import sys
import urllib.parse


def main():
    parser = argparse.ArgumentParser(
        prog=os.path.basename(sys.argv[0]),
        description="Encode or decode URL strings.",
        add_help=False,
    )
    parser.add_argument(
        "-d", "--decode",
        action="store_true",
        default=False,
        help="Decode a URL-encoded string",
    )
    parser.add_argument(
        "-h", "--help",
        action="store_true",
        default=False,
        help="Show this help message",
    )
    parser.add_argument("text", nargs="*")

    try:
        args = parser.parse_args()
    except SystemExit:
        sys.exit(1)

    if args.help:
        prog = os.path.basename(sys.argv[0])
        print(f"Usage: {prog} [-d|--decode] [text...]")
        print()
        print("  Encode or decode URL strings.")
        print()
        print("  Options:")
        print("    -d, --decode    Decode a URL-encoded string")
        print("    -h, --help      Show this help message")
        print()
        print("  Examples:")
        print(f"    {prog} 'hello world'          # -> hello+world")
        print(f"    {prog} 'text,that,works'      # -> text%2Cthat%2Cworks")
        print(f"    {prog} -d 'hello%20world'     # -> hello world")
        print(f"    echo 'hello world' | {prog}   # encode from stdin")
        sys.exit(0)

    if args.text:
        text = " ".join(args.text)
    elif not sys.stdin.isatty():
        text = sys.stdin.read()
    else:
        print(f"Error: no input provided.", file=sys.stderr)
        print(f"Run '{os.path.basename(sys.argv[0])} --help' for usage.", file=sys.stderr)
        sys.exit(1)

    if args.decode:
        print(urllib.parse.unquote_plus(text))
    else:
        print(urllib.parse.quote_plus(text))


if __name__ == "__main__":
    main()
